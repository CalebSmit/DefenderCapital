# Defender Capital Management — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Database (optional — SQLite fallback used if not set) ──────────────────
# Neon PostgreSQL connection string (from neon.tech dashboard)
# Leave empty to use SQLite for local development
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Risk-Free Rate (optional — 4.5% fallback used if not set) ─────────────
# Override the cached risk-free rate (e.g., for backtesting a specific date)
# Format: decimal (e.g., 0.045 for 4.5%)
# DCM_RFR_OVERRIDE=0.045

# ── Cache Settings (optional) ─────────────────────────────────────────────
# Directory for yfinance price cache (default: ./data/cache)
# DCM_CACHE_DIR=./data/cache

# ── Streamlit Secrets (for Streamlit Cloud deployment) ────────────────────
# When deploying to Streamlit Cloud, create .streamlit/secrets.toml with:
#   NEON_DATABASE_URL = "postgresql://..."
