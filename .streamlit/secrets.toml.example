# ──────────────────────────────────────────────────────────────────
# Defender Capital — Streamlit Secrets Template
# ──────────────────────────────────────────────────────────────────
# 1. Copy this file to .streamlit/secrets.toml
# 2. Replace the placeholder with your real Neon connection string
# 3. NEVER commit secrets.toml to Git  (it's in .gitignore already)
# ──────────────────────────────────────────────────────────────────

# Get this from: neon.tech → your project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
NEON_DATABASE_URL = "postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── LOCAL DEVELOPMENT (no Neon) ─────────────────────────────────────
# If NEON_DATABASE_URL is absent or empty, the app automatically
# uses a local SQLite database at  data/dcm_users.db
# No configuration needed for local dev.
